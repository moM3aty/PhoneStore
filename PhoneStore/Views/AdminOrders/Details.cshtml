@model PhoneStore.Models.ViewModels.AdminOrdersViewModel
@using PhoneStore.Extensions

@{
    ViewData["Title"] = "تفاصيل الطلب #" + Model.Order.Id;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var culture = new System.Globalization.CultureInfo("ar-JO");
}

<style>
    body {
        background-color: #f4f7f6; /* لون خلفية هادئ مشابه للصورة */
    }

    .text-primary-custom {
        color: #1a56db !important;
    }

    .bg-primary-custom {
        background-color: #1a56db !important;
    }

    .card-custom {
        border: none;
        border-radius: 0.5rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.04);
        background-color: #fff;
        margin-bottom: 1.5rem;
    }

    .card-header-custom {
        background-color: #fff;
        border-bottom: 1px solid #f0f0f0;
        padding: 1rem 1.5rem;
        border-top-right-radius: 0.5rem; /* تعديل للحواف في العربية */
        border-top-left-radius: 0.5rem;
        font-weight: bold;
        color: #1a56db;
    }

    .icon-circle {
        width: 40px;
        height: 40px;
        background-color: rgba(26, 86, 219, 0.1);
        color: #1a56db;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container-fluid py-4">

    <!-- الهيدر العلوي والأزرار -->
    <div class="d-flex justify-content-between align-items-start align-items-md-center mb-4 flex-column flex-md-row gap-3">
        <!-- العنوان وتاريخ الطلب (سيكون على اليمين) -->
        <div>
            <h3 class="mb-1 fw-bold text-primary-custom">تفاصيل الطلب #@Model.Order.Id</h3>
            <span class="text-muted small">تاريخ الطلب: <span dir="ltr">@Model.Order.OrderDate.ToString("hh:mm tt dd/MM/yyyy")</span></span>
        </div>

        <!-- الأزرار (ستكون على اليسار) -->
        <div class="d-flex gap-2">
            <a asp-action="PrintInvoice" asp-route-id="@Model.Order.Id" class="btn text-white px-4 py-2 rounded-2 d-flex align-items-center shadow-sm" style="background-color: #513061;" target="_blank">
                <i class="fas fa-print ms-2"></i> طباعة الفاتورة
            </a>
            <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-2 shadow-sm d-flex align-items-center text-dark bg-white">
                <i class="fas fa-arrow-right ms-2"></i> العودة
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- قائمة المنتجات (الجانب الأيمن) - col-lg-8 -->
        <div class="col-lg-8">
            <div class="card-custom h-100">
                <div class="card-header-custom d-flex align-items-center">
                    <i class="fas fa-shopping-basket ms-2"></i> المنتجات المطلوبة
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 text-center border-white">
                            <thead style="background-color: #f8f9fa;">
                                <tr>
                                    <!-- الترتيب الطبيعي للجدول بالعربية -->
                                    <th class="text-start ps-4 py-3 text-muted border-0">المنتج</th>
                                    <th class="py-3 text-muted border-0">السعر</th>
                                    <th class="py-3 text-muted border-0">الكمية</th>
                                    <th class="text-end pe-4 py-3 text-muted border-0">الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Order.OrderDetails)
                                {
                                    <tr class="border-bottom">
                                        <td class="text-start ps-4 py-3 border-0">
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "https://placehold.co/60x60/EEE/513061?text=No+Image" : item.Product.ImageUrl)"
                                                     alt="@item.Product?.Name"
                                                     class="border rounded-2 shadow-sm ms-3"
                                                     style="width: 45px; height: 45px; object-fit: cover; flex-shrink: 0;" />
                                                <div>
                                                    <span class="d-block text-dark fw-semibold">@(item.Product?.Name ?? "منتج محذوف")</span>
                                                    <div class="small text-muted mt-1">
                                                        @(item.Product?.Company?.Name)
                                                        @if (!string.IsNullOrEmpty(item.SelectedColor))
                                                        {
                                                            <span class="me-1">- @item.SelectedColor</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.SelectedType))
                                                        {
                                                            <span class="me-1">(@item.SelectedType)</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted border-0 py-3">@item.UnitPrice.ToString("C", culture)</td>
                                        <td class="border-0 py-3">
                                            <span class="border rounded px-3 py-1 bg-white shadow-sm text-dark">@item.Quantity</span>
                                        </td>
                                        <td class="fw-bold text-dark text-end pe-4 border-0 py-3">@((item.UnitPrice * item.Quantity).ToString("C", culture))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- ملخص الدفع -->
                    <div class="p-4 bg-white rounded-bottom">
                        <div class="d-flex justify-content-end w-100">
                            <div style="width: 300px;">
                                <div class="d-flex justify-content-between align-items-center mb-3 text-muted">
                                    <span>المجموع الفرعي:</span>
                                    <span class="fw-bold text-dark">@((Model.Order.TotalAmount - (Model.Order.DeliveryLocation?.DeliveryFee ?? 0)).ToString("C", culture))</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-4 text-success">
                                    <span>رسوم التوصيل (@(Model.Order.DeliveryLocation?.LocationName ?? "غير محدد")):</span>
                                    <span class="fw-bold">+ @(Model.Order.DeliveryLocation != null ? Model.Order.DeliveryLocation.DeliveryFee.ToString("C", culture) : "0.00")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                    <span class="fs-5 fw-bold text-dark">الإجمالي الكلي:</span>
                                    <span class="fs-4 fw-bold text-primary-custom">@Model.Order.TotalAmount.ToString("C", culture)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- التفاصيل الجانبية (الجانب الأيسر) - col-lg-4 -->
        <div class="col-lg-4">

            <!-- تحديث حالة الطلب -->
            <div class="card-custom mb-4">
                <div class="card-header-custom d-flex align-items-center">
                    <i class="fas fa-list-ul ms-2"></i> حالة الطلب
                </div>
                <div class="card-body py-4 px-3">
                    <div class="text-center mb-4">
                        @switch (Model.Order.Status)
                        {
                            case PhoneStore.Models.OrderStatus.Pending:
                                <span class="badge text-dark fs-6 px-4 py-2 rounded-pill shadow-sm" style="background-color: #ffc107;">قيد الانتظار</span>
                                break;
                            case PhoneStore.Models.OrderStatus.Processing:
                                <span class="badge text-dark fs-6 px-4 py-2 rounded-pill shadow-sm" style="background-color: #0dcaf0;">جاري التجهيز</span>
                                break;
                            case PhoneStore.Models.OrderStatus.Shipped:
                                <span class="badge bg-primary fs-6 px-4 py-2 rounded-pill shadow-sm">تم الشحن</span>
                                break;
                            case PhoneStore.Models.OrderStatus.Completed:
                                <span class="badge bg-success fs-6 px-4 py-2 rounded-pill shadow-sm">مكتمل</span>
                                break;
                            case PhoneStore.Models.OrderStatus.Cancelled:
                                <span class="badge bg-danger fs-6 px-4 py-2 rounded-pill shadow-sm">ملغي</span>
                                break;
                        }
                    </div>

                    <form asp-action="UpdateStatus" method="post" class="mt-4 border-top pt-3">
                        <input type="hidden" name="id" value="@Model.Order.Id" />
                        <div class="mb-2">
                            <label class="text-muted small">تحديث الحالة:</label>
                        </div>
                        <div class="input-group">
                            <select name="status" class="form-select" asp-items="Model.StatusList"></select>
                            <button class="btn text-white px-3" style="background-color: #513061;" type="submit" title="حفظ التحديث">
                                <i class="fas fa-check"></i> حفظ
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- بيانات العميل -->
            <div class="card-custom mb-4">
                <div class="card-header-custom d-flex align-items-center">
                    <i class="fas fa-user-circle ms-2"></i> بيانات العميل
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle ms-3 flex-shrink-0">
                            <i class="fas fa-user"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block mb-1">الاسم</span>
                            <span class="fw-bold text-dark">@Model.Order.CustomerName</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle ms-3 flex-shrink-0">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block mb-1">الهاتف</span>
                            <span class="fw-bold text-dark d-block" dir="ltr">@Model.Order.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center">
                        <div class="icon-circle ms-3 flex-shrink-0">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block mb-1">عنوان التوصيل</span>
                            <span class="fw-bold text-dark d-block">@(Model.Order.DeliveryLocation?.LocationName ?? "غير محدد")</span>
                            <span class="text-muted small d-block mt-1">@Model.Order.Address</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- معلومات الدفع -->
            <div class="card-custom">
                <div class="card-header-custom d-flex align-items-center">
                    <i class="fas fa-credit-card ms-2"></i> معلومات الدفع
                </div>
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <span class="text-muted small">طريقة الدفع:</span>
                    <span class="fw-bold text-dark">@Model.Order.PaymentMethod.GetDisplayName()</span>
                </div>
            </div>

        </div>
    </div>
</div>