@model PhoneStore.Models.ViewModels.StoreViewModel
@{
    ViewData["Title"] = "المتجر";
    var culture = new System.Globalization.CultureInfo("ar-JO");

    // --- منطق الأقسام الفرعية ---
    // 1. الأقسام الرئيسية (اللي ملهاش أب)
    var mainCategories = Model.Categories.Where(c => c.ParentCategoryId == null).ToList();

    // 2. معرفة القسم الأب النشط حالياً لإظهار فروعه
    int? activeParentId = null;
    if (Model.SelectedCategoryId != 0)
    {
        var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId);
        if (selectedCat != null)
        {
            activeParentId = selectedCat.ParentCategoryId ?? selectedCat.Id;
        }
    }
}

<!-- الهيدر العلوي (مع الصورة الخلفية الفخمة) -->
<section id="home" class="shop-hero position-relative d-flex flex-column justify-content-center">
    <div class="container position-relative z-2">
        <div class="heading text-center" data-aos="fade-up" data-aos-delay="100">
            <h2 class="mb-3 text-white fw-bold display-5">متجر قطع الغيار</h2>
            <p class="text-light opacity-75 mx-auto fs-5" style="max-width: 600px;">
                نوفر لك مجموعة مميزة من قطع غيار الموبايلات بجودة موثوقة وأسعار تنافسية.
            </p>
        </div>
    </div>
    <div class="hero-overlay"></div>
</section>

<section class="parts py-5 bg-light" id="products">
    <div class="container">

        <!-- القسم العلوي: البحث والشركات فقط -->
        <div class="row mb-4" data-aos="fade-up">
            <div class="col-12">
                <div class="filters-card p-4 bg-white rounded-4 shadow-sm border border-light">
                    
                    <!-- نموذج البحث -->
                    <form asp-action="Index" method="get" class="mb-4 search-form">
                        @if (Model.SelectedCompanyId != 0)
                        {
                            <input type="hidden" name="companyId" value="@Model.SelectedCompanyId" />
                        }
                        @if (Model.SelectedCategoryId != 0)
                        {
                            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                        }

                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white border-end-0 text-muted ps-4"><i class="fas fa-search"></i></span>
                            <input type="text" name="searchString" value="@Model.SearchString" class="form-control border-start-0 ps-2" placeholder="ابحث عن منتج (مثل: شاشة ايفون 11)...">
                            <button class="btn btn-brand px-4 px-md-5 fw-bold rounded-end-pill" type="submit">بحث</button>
                        </div>
                    </form>

                    <!-- فلتر الشركات -->
                    <div>
                        <h6 class="fw-bold text-dark mb-3 small d-flex align-items-center">
                            <i class="fas fa-building me-2 text-primary-custom"></i> تصفح حسب الشركة
                        </h6>
                        <div class="d-flex flex-wrap gap-2 filter-scroll">
                            <a asp-action="Index"
                               asp-route-categoryId="@(Model.SelectedCategoryId == 0 ? null : Model.SelectedCategoryId)"
                               asp-route-searchString="@Model.SearchString"
                               class="custom-pill @(Model.SelectedCompanyId == 0 ? "active" : "")">
                                الكل
                            </a>
                            @foreach (var company in Model.Companies)
                            {
                                <a asp-action="Index"
                                   asp-route-companyId="@company.Id"
                                   asp-route-categoryId="@(Model.SelectedCategoryId == 0 ? null : Model.SelectedCategoryId)"
                                   asp-route-searchString="@Model.SearchString"
                                   class="custom-pill @(Model.SelectedCompanyId == company.Id ? "active" : "")">
                                    @company.Name
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- القائمة الجانبية: الأقسام وتفرعاتها -->
            <div class="col-lg-3" data-aos="fade-up" data-aos-delay="50">
                <div class="categories-sidebar bg-white rounded-4 shadow-sm border border-light p-4 sticky-lg-top" style="top: 100px; z-index: 10;">
                    <h6 class="fw-bold text-dark mb-4 d-flex align-items-center pb-3 border-bottom">
                        <i class="fas fa-sitemap me-2 text-primary-custom"></i> الأقسام المتاحة
                    </h6>
                    
                    <div class="d-flex flex-column gap-2">
                        <!-- عرض كل المنتجات -->
                        <a asp-action="Index"
                           asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                           asp-route-searchString="@Model.SearchString"
                           class="sidebar-link @(Model.SelectedCategoryId == 0 ? "active" : "")">
                            <i class="fas fa-border-all me-2 opacity-50"></i> عرض كل المنتجات
                        </a>

                        <!-- الأقسام الرئيسية والفرعية -->
                        @foreach (var category in mainCategories)
                        {
                            bool isParentActive = activeParentId == category.Id;
                            var subCategories = Model.Categories.Where(c => c.ParentCategoryId == category.Id).ToList();

                            <a asp-action="Index"
                               asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                               asp-route-categoryId="@category.Id"
                               asp-route-searchString="@Model.SearchString"
                               class="sidebar-link @(isParentActive ? "active" : "") d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-angle-left me-2 opacity-50" style="font-size:0.8rem;"></i> @category.Name</span>
                                @if (subCategories.Any())
                                {
                                    <i class="fas @(isParentActive ? "fa-folder-open" : "fa-folder") opacity-50 small"></i>
                                }
                            </a>

                            <!-- الأقسام الفرعية تظهر كشجرة منسدلة أسفل القسم الرئيسي النشط -->
                            @if (isParentActive && subCategories.Any())
                            {
                                <div class="sub-categories-wrapper ps-4 pe-2 py-2 mb-2 border-start border-2 border-light d-flex flex-column gap-1">
                                    <a asp-action="Index"
                                       asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                                       asp-route-categoryId="@category.Id"
                                       asp-route-searchString="@Model.SearchString"
                                       class="sidebar-sub-link @(Model.SelectedCategoryId == category.Id ? "active" : "")">
                                        كل @category.Name
                                    </a>
                                    @foreach (var sub in subCategories)
                                    {
                                        <a asp-action="Index"
                                           asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                                           asp-route-categoryId="@sub.Id"
                                           asp-route-searchString="@Model.SearchString"
                                           class="sidebar-sub-link @(Model.SelectedCategoryId == sub.Id ? "active" : "")">
                                            @sub.Name
                                        </a>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- منطقة المنتجات -->
            <div class="col-lg-9">
                <!-- شريط معلومات النتائج -->
                <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap pb-2 border-bottom border-light">
                    <h5 class="fw-bold text-dark mb-2 mb-md-0">
                        @if (!string.IsNullOrEmpty(Model.SearchString))
                        {
                            <span>نتائج البحث عن: <span class="text-primary-custom">"@Model.SearchString"</span></span>
                        }
                        else
                        {
                            @(Model.SelectedCategoryId != 0 ? Model.Categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId)?.Name : "أحدث المنتجات")
                        }

                        @if (Model.SelectedCompanyId != 0)
                        {
                            <span class="text-muted fw-normal fs-6"> - @Model.Companies.FirstOrDefault(c => c.Id == Model.SelectedCompanyId)?.Name</span>
                        }
                    </h5>
                    <span class="text-muted small bg-white px-3 py-1 rounded-pill shadow-sm border">@Model.Products.Count() منتجات معروضة</span>
                </div>

                <!-- شبكة المنتجات -->
                <div class="row g-3 g-md-4" id="products-container">
                    @if (!Model.Products.Any())
                    {
                        <div class="col-12" data-aos="fade-in">
                            <div class="text-center py-5 bg-white rounded-4 border border-dashed shadow-sm">
                                <div class="mb-3 text-muted opacity-50">
                                    <i class="fas fa-box-open fa-4x"></i>
                                </div>
                                <h4 class="fw-bold text-dark">لا توجد منتجات تطابق بحثك حالياً.</h4>
                                <p class="text-muted">جرب تغيير كلمات البحث أو اختيار قسم مختلف.</p>
                                <a asp-action="Index" class="btn btn-brand mt-3 rounded-pill px-5 py-2 fw-bold">إزالة الفلاتر</a>
                            </div>
                        </div>
                    }

                    @foreach (var item in Model.Products)
                    {
                        <div class="col-6 col-md-6 col-xl-4" data-aos="fade-up">
                            <!-- التعديل 1: إضافة d-flex flex-column للكارت الرئيسي -->
                            <div class="product-card position-relative overflow-hidden h-100 bg-white border rounded-4 shadow-hover transition-all d-flex flex-column">
                                
                                @if (item.DiscountPercentage > 0)
                                {
                                    <div class="position-absolute top-0 end-0 m-2 bg-danger text-white px-2 py-1 rounded-3 small fw-bold z-2 shadow-sm">
                                        -@item.DiscountPercentage%
                                    </div>
                                }

                                <div class="wishlist position-absolute top-0 start-0 z-2 m-2">
                                    <button class="btn btn-light rounded-circle shadow-sm p-0 d-flex align-items-center justify-content-center btn-toggle-wishlist" 
                                            data-id="@item.Id" 
                                            style="width: 35px; height: 35px;"
                                            title="@(Model.WishlistIds.Contains(item.Id) ? "إزالة من المفضلة" : "إضافة للمفضلة")">
                                        @if (Model.WishlistIds.Contains(item.Id))
                                        {
                                            <i class="fa-solid fa-heart text-danger"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-heart text-muted"></i>
                                        }
                                    </button>
                                </div>

                                <div class="product-img bg-light position-relative" style="height: 220px; display: flex; align-items: center; justify-content: center; padding: 1rem;">
                                    <a asp-controller="Store" asp-action="Details" asp-route-id="@item.Id" class="d-block w-100 h-100">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/400x400/EEE/513061?text=No+Image" : item.ImageUrl)" 
                                             alt="@item.Name" 
                                             class="img-fluid w-100 h-100 object-fit-contain transition-transform">
                                    </a>
                                </div>

                                <!-- التعديل 2: تغيير h-100 إلى flex-grow-1 ليأخذ المساحة المتبقية بدون الخروج عن الإطار -->
                                <div class="product-info p-3 d-flex flex-column flex-grow-1">
                                    <div class="mb-1">
                                        <span class="text-uppercase text-muted x-small fw-bold">@item.Company?.Name</span>
                                        @if(item.Category != null)
                                        {
                                            <span class="text-muted x-small"> • @item.Category.Name</span>
                                        }
                                    </div>
                                    <h6 class="fw-bold text-dark mb-2 text-truncate">
                                        <a asp-controller="Store" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                            @item.Name
                                        </a>
                                    </h6>
                                    
                                    <div class="d-flex justify-content-between align-items-end mt-auto pt-3">
                                        <div class="price">
                                            @if (item.OldPrice.HasValue && item.OldPrice > item.Price)
                                            {
                                                <div class="text-muted text-decoration-line-through x-small">@item.OldPrice.Value.ToString("C", culture)</div>
                                                <div class="text-danger fw-bold">@item.Price.ToString("C", culture)</div>
                                            }
                                            else
                                            {
                                                <div class="fw-bold" style="color: #513061;">@item.Price.ToString("C", culture)</div>
                                            }
                                        </div>
                                        <!-- تم إصلاح وتوحيد الـ Style هنا ليظهر الزر بوضوح -->
                                        <button class="btn text-white rounded-circle p-0 d-flex align-items-center justify-content-center btn-add-to-cart shadow-sm" 
                                                style="background-color: #513061; width: 38px; height: 38px; flex-shrink: 0;"
                                                data-id="@item.Id"
                                                title="أضف للسلة">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- التصفح (Pagination) -->
                @if (Model.TotalPages > 1)
                {
                    <div class="row mt-5 mb-4" data-aos="fade-up">
                        <div class="col-12">
                            <nav aria-label="Page navigation">
                                <ul class="pagination custom-pagination justify-content-center mb-0 gap-2">
                                    <!-- زر السابق -->
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link shadow-sm"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage - 1)"
                                           asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                                           asp-route-categoryId="@(Model.SelectedCategoryId == 0 ? null : Model.SelectedCategoryId)"
                                           asp-route-searchString="@Model.SearchString">
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </li>

                                    <!-- أرقام الصفحات -->
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                                        {
                                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                                <a class="page-link shadow-sm fw-bold"
                                                   asp-action="Index"
                                                   asp-route-page="@i"
                                                   asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                                                   asp-route-categoryId="@(Model.SelectedCategoryId == 0 ? null : Model.SelectedCategoryId)"
                                                   asp-route-searchString="@Model.SearchString">
                                                    @i
                                                </a>
                                            </li>
                                        }
                                        else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                                        {
                                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                                        }
                                    }

                                    <!-- زر التالي -->
                                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link shadow-sm"
                                           asp-action="Index"
                                           asp-route-page="@(Model.CurrentPage + 1)"
                                           asp-route-companyId="@(Model.SelectedCompanyId == 0 ? null : Model.SelectedCompanyId)"
                                           asp-route-categoryId="@(Model.SelectedCategoryId == 0 ? null : Model.SelectedCategoryId)"
                                           asp-route-searchString="@Model.SearchString">
                                            <i class="fas fa-chevron-left"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

@section Styles {
<style>
    /* المتغيرات الأساسية للهوية البصرية */
    :root {
        --store-primary: #513061;
        --store-primary-hover: #432552;
    }

    .text-primary-custom {
        color: var(--store-primary) !important;
    }

    /* الهيدر مع إضافة خلفية احترافية */
    .shop-hero {
        min-height: 35vh;
        background-color: #1a1a1d;
        /* تمت إضافة صورة خلفية للهيدر مع تدرج لوني */
        background-image: linear-gradient(rgba(26, 26, 29, 0.85), rgba(81, 48, 97, 0.85)), url('https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        overflow: hidden;
    }
    .hero-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: url('data:image/svg+xml,%3Csvg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="%23ffffff" fill-opacity="0.03" fill-rule="evenodd"%3E%3Ccircle cx="3" cy="3" r="3"/%3E%3Ccircle cx="13" cy="13" r="3"/%3E%3C/g%3E%3C/svg%3E');
        z-index: 1;
    }

    /* نموذج البحث */
    .search-form .form-control:focus {
        border-color: #dee2e6;
        box-shadow: none;
    }
    .search-form .input-group {
        border: 2px solid #e9ecef;
        border-radius: 0.75rem;
        overflow: hidden;
        transition: border-color 0.3s;
    }
    .search-form .input-group:focus-within {
        border-color: var(--store-primary);
    }
    .btn-brand {
        background-color: var(--store-primary);
        color: white;
        border-radius: 0;
    }
    .btn-brand:hover {
        background-color: var(--store-primary-hover);
        color: white;
    }

    /* أزرار الفلترة للشركات (Pills) */
    .filter-scroll {
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }
    .filter-scroll::-webkit-scrollbar {
        display: none; 
    }

    .custom-pill {
        display: inline-block;
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        white-space: nowrap;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        color: #495057;
    }
    .custom-pill:hover, .custom-pill.active {
        background-color: var(--store-primary);
        color: white;
        border-color: var(--store-primary);
        box-shadow: 0 4px 10px rgba(81, 48, 97, 0.2);
    }

    /* ستايلات القائمة الجانبية للأقسام (Sidebar Categories) */
    .sidebar-link {
        display: block;
        padding: 0.75rem 1rem;
        color: #495057;
        font-weight: 600;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }
    .sidebar-link:hover {
        background-color: #f8f9fa;
        color: var(--store-primary);
    }
    .sidebar-link.active {
        background-color: #fbf9fc;
        color: var(--store-primary);
        font-weight: 700;
        border-color: rgba(81, 48, 97, 0.1);
    }
    .sidebar-sub-link {
        display: block;
        padding: 0.5rem 1rem;
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 0.5rem;
        transition: all 0.2s ease;
    }
    .sidebar-sub-link:hover {
        color: var(--store-primary);
        background-color: #f8f9fa;
    }
    .sidebar-sub-link.active {
        color: var(--store-primary);
        background-color: #fbf9fc;
        font-weight: 700;
    }

    /* ستايلات كارت المنتج القديم */
    .x-small { 
        font-size: 0.75rem; 
    }
    .transition-all { 
        transition: all 0.3s ease; 
    }
    .shadow-hover:hover { 
        box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important; 
        transform: translateY(-5px); 
    }
    .product-card:hover .transition-transform { 
        transform: scale(1.08); 
    }
    
    /* تأثير زر السلة */
    .btn-add-to-cart:hover {
        background-color: var(--store-primary-hover) !important;
        transform: scale(1.1);
        transition: all 0.3s ease;
    }

    /* التصفح (Pagination) */
    .custom-pagination .page-link {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50% !important;
        border: none;
        color: #495057;
        margin: 0;
        transition: all 0.2s;
    }
    .custom-pagination .page-link:hover {
        background-color: #f1f3f5;
        color: var(--store-primary);
    }
    .custom-pagination .page-item.active .page-link {
        background-color: var(--store-primary);
        color: white;
    }
    .custom-pagination .page-item.disabled .page-link {
        background-color: transparent;
        box-shadow: none !important;
    }
</style>
}